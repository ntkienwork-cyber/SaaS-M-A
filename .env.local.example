# ── Database ─────────────────────────────────────────────────────────────────

# Supabase → Project Settings → Database → Connection string → URI (Transaction pooler)
DATABASE_URL=

# Supabase → Project Settings → Database → Connection string → URI (Session mode / direct)
# Required by Prisma for migrations
DIRECT_URL=

# ── NextAuth — generate with: openssl rand -base64 32 ────────────────────────
AUTH_SECRET=

# ── OAuth Providers ──────────────────────────────────────────────────────────

# Google: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook: https://developers.facebook.com → App → Facebook Login settings
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Apple: https://developer.apple.com → Certificates → Services IDs
# APPLE_CLIENT_ID   = Services ID (e.g. com.company.bizconnect)
# APPLE_CLIENT_SECRET = pre-signed JWT; see https://authjs.dev/guides/providers/apple
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── Firebase ─────────────────────────────────────────────────────────────────

# Server-side Admin SDK (never expose publicly)
# From Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full private key with literal \n — keep the surrounding quotes in .env.local
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Client-side SDK (safe to expose — restricted by Firebase security rules)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Supabase ─────────────────────────────────────────────────────────────────

# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Use the service_role key (server-only; never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=
